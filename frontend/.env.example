# Backend URL (production'da gerekli, gelishtirmede proxy kullanilir)
# VITE_BACKEND_URL=https://fikir-nine-backend.up.railway.app

# Firebase (console.firebase.google.com -> Project Settings -> Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# Google Analytics 4 (analytics.google.com)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXX

# Android APK indirme linki (EAS build bitince expo.dev'den alinan URL)
# VITE_APK_DOWNLOAD_URL=https://expo.dev/artifacts/eas/xxxxxx.apk

# ── Reklam Ayarlari ──────────────────────────────────────
# Saglayici: "adsense", "adsterra", "custom", veya bos birakirsan "placeholder" kullanilir
# VITE_AD_PROVIDER=adsense

# Google AdSense (VITE_AD_PROVIDER=adsense ise gerekli)
# VITE_ADSENSE_PUBLISHER_ID=ca-pub-XXXXX
# VITE_ADSENSE_SLOT_BANNER=1234567890
# VITE_ADSENSE_SLOT_KART=1234567891
# VITE_ADSENSE_SLOT_DETAY=1234567892

# Adsterra (VITE_AD_PROVIDER=adsterra ise gerekli)
# VITE_ADSTERRA_KEY=229e2d2bc9d6c030fa1b29222ebd0ea4
# Sayfada birden fazla reklam alani varsa varsayilan olarak tek instance yuklenir (true).
# Iki ReklamAlani ayni anda kullanacaksan 'false' yapabilirsin (cakisabilir).
# VITE_ADSTERRA_SINGLETON=true

# Ozel reklam agi (VITE_AD_PROVIDER=custom ise gerekli)
# Media.net, PropellerAds, vb. icin script URL'si
# VITE_CUSTOM_AD_SCRIPT_URL=https://example.com/ad-script.js
# VITE_CUSTOM_AD_ATTR=data-zone-id=12345
