# Runtime
NODE_ENV=development
TRUST_PROXY=1
MAX_BODY_KB=256
FETCH_TIMEOUT_MS=20000

# Gemini API key (https://aistudio.google.com/app/apikey)
# GEMINI_API_KEY=AIzaSy...

# Model (ucuz varsayilan: Gemini 2.5 Flash)
# GEMINI_MODEL=gemini-2.5-flash

# Yedek Model (API istegi basarisiz olursa denenecek model)
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# Sunucu portu (Railway otomatik atar)
PORT=3001

# Firebase Admin (console.firebase.google.com -> Project Settings -> Service Accounts -> JSON indir)
# Tek satir JSON olarak yapistir
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Redis (Railway Add Plugin -> Redis ekleyince otomatik REDIS_URL atanir)
# REDIS_URL=redis://default:xxxxx@containers-us-west-xxx.railway.app:6379
# Production'da Redis zorunlu kalsin
REQUIRE_REDIS_IN_PROD=true

# Reklam odul ayarlari
# Production'da zorunlu: REKLAM_ODUL_SECRET=uzun-ve-rastgele-bir-gizli-anahtar
# REKLAM_ODUL_LIMIT=3
# REKLAM_ODUL_OTURUM_TTL_MS=600000
# REKLAM_ODUL_MIN_BEKLEME_MS=8000

# Ek CORS origin'ler (virgul ile ayir; frontend farkli domaindeyse)
# CORS_ORIGINS=https://www.example.com,https://app.example.com
